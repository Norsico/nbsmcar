   26          //  @brief      ADC魹ｽ魹ｽﾊｼ魹ｽ魹ｽ
   27          //  @param      adcn            ﾑ｡魹ｽ魹ｽADCﾍｨ魹ｽ魹ｽ
   28          //  @param      speed                   ADCﾊｱ魹ｽ魹ｽﾆｵ魹ｽ魹ｽ
   29          //  @return     void
   30          //  Sample usage:               adc_init(ADC_P10,ADC_SYSclk_DIV_2);//魹ｽ魹ｽﾊｼ魹ｽ魹ｽP1.0ﾎｪADC魹ｽ魹ｽ魹ｽ魹ｽ,
             -ADCﾊｱ魹ｽ魹ｽﾆｵ魹ｽﾊ｣魹ｽSYSclk/2
   31          //-------------------------------------------------------------------------------------------------------
             -------------
   32          void adc_init(ADCN_enum adcn,ADC_SPEED_enum speed)
   33          {
   34   1              ADC_CONTR |= 1<<7;                              //1 魹ｽ魹ｽ魹ｽ魹ｽ ADC 魹ｽ魹ｽﾔｴ
   35   1              
   36   1              ADC_CONTR &= (0xF0);                    //魹ｽ魹ｽ魹ｽADC_CHS[3:0] 魹ｽ魹ｽ ADC ﾄ｣魹ｽ魹ｽﾍｨ魹ｽ魹ｽﾑ｡魹ｽ魹ｽﾎｻ
   37   1              ADC_CONTR |= adcn;
   38   1              
   39   1              if((adcn >> 3) == 1) //P0.0
   40   1              {
   41   2                      //IO魹ｽ魹ｽ魹ｽ魹ｽﾒｪ魹ｽ魹ｽ魹ｽ魹ｽﾎｪ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
   42   2                      P0M0 &= ‾(1 << (adcn & 0x07));
   43   2                      P0M1 |= (1 << (adcn & 0x07));
   44   2              }
   45   1              else if((adcn >> 3) == 0) //P1.0        
   46   1              {
   47   2                      //IO魹ｽ魹ｽ魹ｽ魹ｽﾒｪ魹ｽ魹ｽ魹ｽ魹ｽﾎｪ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
   48   2                      P1M0 &= ‾(1 << (adcn & 0x07));
C251 COMPILER V5.60.0,  zf_adc                                                             17/08/24  10:34:30  PAGE 2   

   49   2                  P1M1 |= (1 << (adcn & 0x07));
   50   2              }
   51   1      
   52   1              ADCCFG |= speed&0x0F;                   //ADCﾊｱ魹ｽ魹ｽﾆｵ魹ｽ魹ｽSYSclk/2/speed&0x0F;
   53   1              
   54   1              ADCCFG |= 1<<5;                                 //ﾗｪ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾒｶ魹ｽ魹ｽ槩｣ ADC_RES 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾄｸ魹ｽ 2 ﾎｻ魹ｽ魹ｽ ADC_
             -RESL 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾄｵ魹ｽ 8 ﾎｻ魹ｽ魹ｽ
   55   1      }
