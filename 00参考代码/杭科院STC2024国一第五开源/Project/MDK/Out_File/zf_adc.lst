   57          
   58          
   59          //-------------------------------------------------------------------------------------------------------
             -------------
   60          //  @brief      ADCﾗｪ魹ｽ魹ｽﾒｻ魹ｽ魹ｽ
   61          //  @param      adcn            ﾑ｡魹ｽ魹ｽADCﾍｨ魹ｽ魹ｽ
   62          //  @param      resolution      魹ｽﾖｱ魹ｽ魹ｽ魹ｽ
   63          //  @return     void
   64          //  Sample usage:               adc_convert(ADC_P10, ADC_10BIT);
   65          //-------------------------------------------------------------------------------------------------------
             -------------
   66          uint16 adc_once(ADCN_enum adcn,ADCRES_enum resolution)
   67          {
   68   1              uint16 adc_value;
   69   1              
   70   1              ADC_CONTR &= (0xF0);                    //魹ｽ魹ｽ魹ｽADC_CHS[3:0] 魹ｽ魹ｽ ADC ﾄ｣魹ｽ魹ｽﾍｨ魹ｽ魹ｽﾑ｡魹ｽ魹ｽﾎｻ
   71   1              ADC_CONTR |= adcn;
   72   1              
   73   1              ADC_CONTR |= 0x40;                      // 魹ｽ魹ｽ魹ｽ魹ｽ AD ﾗｪ魹ｽ魹ｽ
   74   1              while (!(ADC_CONTR & 0x20));    // 魹ｽ魹ｽﾑｯ ADC 魹ｽ魹ｽﾉｱ魹ｽﾖｾ
   75   1              ADC_CONTR &= ‾0x20;                     // 魹ｽ魹ｽ魹ｽ魹ｽﾉｱ魹ｽﾖｾ
   76   1              
   77   1              adc_value = ADC_RES;                    //魹ｽ豢｢ ADC 魹ｽ魹ｽ 12 ﾎｻ魹ｽ魹ｽ魹ｽ魹ｽﾄｸ魹ｽ 4 ﾎｻ
   78   1              adc_value <<= 8;
   79   1              adc_value |= ADC_RESL;                  //魹ｽ豢｢ ADC 魹ｽ魹ｽ 12 ﾎｻ魹ｽ魹ｽ魹ｽ魹ｽﾄｵ魹ｽ 8 ﾎｻ
   80   1              
   81   1              ADC_RES = 0;
   82   1              ADC_RESL = 0;
   83   1              
   84   1              adc_value >>= resolution;               //ﾈ｡魹ｽ魹ｽ魹ｽ魹ｽﾎｻ
   85   1              
   86   1      
   87   1              return adc_value;
   88   1      }


