   30          
   31          void Ladrc_Td(LADRC_NUM *LADRC_,float expect)
   32          {
   33   1          float fh = -LADRC_->r*LADRC_->r*(LADRC_->v1-expect)-2*LADRC_->r*LADRC_->v2;
   34   1          LADRC_->v1+=LADRC_->v2*LADRC_->h;
   35   1          LADRC_->v2+=fh*LADRC_->h;
   36   1      }
   37          
   38          void Ladrc_Eso(LADRC_NUM *LADRC_,float feedback)
   39          {
   40   1          float B1=3*LADRC_->w0;
   41   1          float B2=3*LADRC_->w0*LADRC_->w0;
   42   1          float B3=LADRC_->w0*LADRC_->w0*LADRC_->w0;
   43   1          float e= LADRC_->z1-feedback;
   44   1          LADRC_->z1+= (LADRC_->z2 - B1*e)*LADRC_->h;
   45   1          LADRC_->z2+= (LADRC_->z3 - B2*e + LADRC_->b0*LADRC_->u)*LADRC_->h;
   46   1          LADRC_->z3+=-B3*e*LADRC_->h;    
   47   1      }
   48          
   49          int decelerate_max = 8000;
   50          int increase_max = 4000;
   51          
   52          void  Ladrc_Lf(LADRC_NUM *LADRC_)
   53          {
   54   1          float Kp=LADRC_->wc*LADRC_->wc;
   55   1          float Kd=2*LADRC_->wc;//kdÝÑôò¢èØåöˆ3
   56   1      
   57   1          float e1=LADRC_->v1-LADRC_->z1;
C251 COMPILER V5.60.0,  Servo                                                              17/08/24  10:34:33  PAGE 2   

   58   1          float e2=LADRC_->v2-LADRC_->z2;
   59   1          float u0=Kp*e1+Kd*e2;
   60   1          LADRC_->u=(u0-LADRC_->z3)/LADRC_->b0;
   61   1          if(LADRC_->u>increase_max)
   62   1              LADRC_->u=increase_max;
   63   1          else if(LADRC_->u<-decelerate_max)
   64   1              LADRC_->u=-decelerate_max;
   65   1      }
