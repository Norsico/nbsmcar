  266          float Kp_Increase(float derr,float kp)
  267          {
  268   1          static uint8 add_count=0;
  269   1          uint8 i;
  270   1          uint32 sum=1;
  271   1          uint8 step = 5;//control timer
  272   1          uint8 max_p=MaxP;
  273   1          uint8 change=P_Rate;
  274   1          if (derr>0) {add_count+=step;}
  275   1          else        {add_count-=step;}
  276   1      
  277   1          for ( i = 0; i < add_count; i++)
  278   1          {
  279   2              sum=sum*kp;
  280   2              if (sum>max_p)//*change
  281   2              {
  282   3                  break;
  283   3              }
  284   2          }
  285   1          // sum=exp(add_count);
  286   1          sum=sum/change;
  287   1          if (sum>max_p){sum=max_p;}//kp limited
  288   1      
  289   1          return sum;
  290   1      }
