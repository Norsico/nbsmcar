   56          //-------------------------------------------------------------------------------------------------------
             -------------
   57          //  @brief      TSL1401线阵CCD图像发送至上位机查看图像
   58          //  @param      uart_n                  串口号
   59          //  @param      uart_n                  线性CCD数据指针
   60          //  @return     void                    
   61          //  @since      v1.0
   62          //  Sample usage:                               调用该函数前请先初始化串口
   63          //-------------------------------------------------------------------------------------------------------
             -------------
   64          void ccd_send_data(UARTN_enum uart_n ,uint16 *dat)
   65          {
   66   1         uint8 i = 0;
   67   1         uart_putchar(uart_n,0x00); 
   68   1         uart_putchar(uart_n,0xff);
   69   1         uart_putchar(uart_n,0x01);
   70   1         uart_putchar(uart_n,0x00);
   71   1         
   72   1              for(i=0; i<128; i++)        
   73   1              {
   74   2                      uart_putchar(uart_n, (uint8)(dat[i]>>8));   //发送高8位
   75   2                      uart_putchar(uart_n, (uint8)(dat[i]&0XFF)); //发送高低8位          
   76   2              }
   77   1      }
   78          
   79          
   80          //-------------------------------------------------------------------------------------------------------
             -------------
   81          //  @brief      TSL1401线阵CCD数据采集
   82          //  @param      NULL
   83          //  @return     void
   84          //  @since      v1.0
   85          //  Sample usage:                               在isr.c里面先创建对应的中断函数，然后调用该函数(之后别忘记
             -清除中断标志位)
   86          //-------------------------------------------------------------------------------------------------------
             -------------
   87          void ccd_collect(void)
   88          {
   89   1          uint8 i = 0;
   90   1      
   91   1          CCD_CLK(1);
   92   1          CCD_SI(0);
   93   1              CCD_CLK(0);
   94   1          CCD_SI(1);
   95   1          CCD_CLK(1);
   96   1          CCD_SI(0);
   97   1              
   98   1          for(i=0;i<128;i++)
   99   1          {
  100   2                      CCD_CLK(0);  
  101   2                      ccd_data_ch1[i] = adc_once(AD_CHANNEL_CH1, AD_RESOLUTION); 
  102   2                      ccd_data_ch2[i] = adc_once(AD_CHANNEL_CH2, AD_RESOLUTION);
  103   2                      // ccd_data_ch3[i] = adc_once(AD_CHANNEL_CH3, AD_RESOLUTION);
  104   2                      CCD_CLK(1); 
  105   2          }
  106   1              tsl1401_finish_flag = 1;
  107   1      }


