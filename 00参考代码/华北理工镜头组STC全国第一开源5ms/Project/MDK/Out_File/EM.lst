    7          
    8          
    9          void infrared_detection()
   10          {  
   11   1        int16   RightADC[20],LeftADC[20]; 
   12   1        int i;
   13   1        int Right_Sum=0,Left_Sum=0;
   14   1        for(i=0;i<20;i++)
   15   1        {   
   16   2          LeftADC[i]=adc_once(ADC_P11, ADC_12BIT);   
   17   2          Left_Sum+=LeftADC[i];
   18   2          RightADC[i]=adc_once(ADC_P14, ADC_12BIT);  
   19   2          Right_Sum+=RightADC[i];
   20   2        }
   21   1        LeftAverage=Left_Sum/20;
   22   1        RightAverage=Right_Sum/20; 
   23   1        AD_Lift =LeftAverage*3.30/4096;
   24   1        AD_Right=RightAverage*3.30/4096;
   25   1       
   26   1        distance_L=26.481*pow(AD_Lift,(-1.05));   
   27   1        distance_R=26.481*pow(AD_Right,(-1.05));   
   28   1      
   29   1        if(distance_L>150.00) distance_L=150.00;        
